<mxfile host="Electron" version="29.6.6" pages="5">
  <diagram id="p17-overview" name="01 P17 项目总览">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ov-title" value="FoodMap P17：体验可信度与移动主路径收束" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="30" width="1240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ov-current" value="当前基线&#xa;&#xa;1. P16 真实地点联动已形成基线&#xa;2. 扫街榜 50 条可作为参考图层&#xa;3. 个人收藏、待确认、手动挪动已有雏形&#xa;4. 详情页、筛选栏、图钉视觉已有多轮优化&#xa;&#xa;仍存在：待确认处理分散、详情层级拥挤、移动端路径不稳、图钉和筛选体验需要阶段性收束。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8ea;strokeColor=#c76a32;fontSize=16;align=left;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="70" y="140" width="340" height="350" as="geometry" />
        </mxCell>
        <mxCell id="ov-target" value="P17 目标体验&#xa;&#xa;用户在手机和桌面都能完成：&#xa;查看地图 -&gt; 进入待确认 -&gt; 看详情 -&gt; 编辑标签 -&gt; 确认候选或挪动图钉 -&gt; 打开地图 App -&gt; 按标签筛选 -&gt; 导出分享图。&#xa;&#xa;所有不可信地点必须可见、可解释、可处理。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5ef;strokeColor=#2f7d8c;fontSize=16;align=left;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="530" y="140" width="350" height="350" as="geometry" />
        </mxCell>
        <mxCell id="ov-guard" value="阶段约束&#xa;&#xa;1. 纯前端、本地优先&#xa;2. 不引入账号/后端/云同步&#xa;3. 不自动修正所有错点&#xa;4. 坐标固化必须用户确认&#xa;5. 扫街榜和参考层不污染个人图&#xa;6. 多尺寸和真实数据必须验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4efe4;strokeColor=#d8c5a5;fontSize=16;align=left;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="1000" y="140" width="330" height="350" as="geometry" />
        </mxCell>
        <mxCell id="ov-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#806b57;endArrow=block;" edge="1" parent="1" source="ov-current" target="ov-target"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ov-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#806b57;endArrow=block;" edge="1" parent="1" source="ov-target" target="ov-guard"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ov-docs" value="本阶段文档&#xa;&#xa;PRD&#xa;目标架构&#xa;开发及验收计划&#xa;项目里程碑&#xa;验收门槛&#xa;Gap 文档&#xa;P17 实施契约" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=16;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="585" width="300" height="210" as="geometry" />
        </mxCell>
        <mxCell id="ov-accept" value="出门证据&#xa;&#xa;npm run build&#xa;npm test&#xa;npx playwright test&#xa;npm run verify:scanlist&#xa;多尺寸截图&#xa;真实数据性能验收&#xa;PRD 规格检视" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=16;align=center;" vertex="1" parent="1">
          <mxGeometry x="800" y="585" width="310" height="210" as="geometry" />
        </mxCell>
        <mxCell id="ov-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2f7d8c;endArrow=block;" edge="1" parent="1" source="ov-docs" target="ov-accept"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p17-architecture-gap" name="02 当前架构与目标架构差异">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ag-title" value="当前架构 vs P17 目标架构" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="30" width="1200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ag-current" value="当前架构&#xa;&#xa;Workspace UI&#xa;PlaceDetailDrawer&#xa;HomeMapControlDock&#xa;manualPinMove&#xa;PlaceSearchProvider&#xa;ExternalMapLinks&#xa;MapPosterExporter&#xa;Agent Bridge&#xa;Recommendation/Reference layers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8ea;strokeColor=#c76a32;fontSize=16;align=left;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="300" height="390" as="geometry" />
        </mxCell>
        <mxCell id="ag-target" value="P17 目标架构&#xa;&#xa;PendingPlaceWorkbench&#xa;PlaceDetailInformationArchitecture&#xa;PinMoveController&#xa;FilterCommandBar&#xa;PinVisualStateModel&#xa;SharePosterPreview&#xa;PerformanceAcceptanceHarness&#xa;AgentPendingPlaceContext" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5ef;strokeColor=#2f7d8c;fontSize=16;align=left;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="1030" y="150" width="300" height="390" as="geometry" />
        </mxCell>
        <mxCell id="ag-gap1" value="缺口 1：待确认处理分散&#xa;需要集中工作台：候选确认、跳过、手动挪动、进度和风险说明。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=15;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="120" width="380" height="88" as="geometry" />
        </mxCell>
        <mxCell id="ag-gap2" value="缺口 2：详情页层级拥挤&#xa;需要状态/标签/核心操作/照片/记录/校准/导航的稳定信息架构。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=15;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="230" width="380" height="88" as="geometry" />
        </mxCell>
        <mxCell id="ag-gap3" value="缺口 3：移动端主路径不稳&#xa;详情、底部栏、挪动模式、地图跳转和分享入口需要互斥且可滚动。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=15;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="340" width="380" height="88" as="geometry" />
        </mxCell>
        <mxCell id="ag-gap4" value="缺口 4：筛选和图钉视觉需要统一&#xa;多尺寸不截断；图钉已核验/待确认/选中/榜单/参考层可区分。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=15;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="450" width="380" height="88" as="geometry" />
        </mxCell>
        <mxCell id="ag-gap5" value="缺口 5：分享图和性能需真实数据验收&#xa;当前筛选/视野一致；扫街榜、参考层、个人收藏、待确认共同压测。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=15;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="560" width="380" height="88" as="geometry" />
        </mxCell>
        <mxCell id="ag-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#806b57;endArrow=block;" edge="1" parent="1" source="ag-current" target="ag-gap1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#806b57;endArrow=block;" edge="1" parent="1" source="ag-current" target="ag-gap2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#806b57;endArrow=block;" edge="1" parent="1" source="ag-current" target="ag-gap3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag-e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#806b57;endArrow=block;" edge="1" parent="1" source="ag-current" target="ag-gap4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag-e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#806b57;endArrow=block;" edge="1" parent="1" source="ag-current" target="ag-gap5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag-e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2f7d8c;endArrow=block;" edge="1" parent="1" source="ag-gap1" target="ag-target"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag-e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2f7d8c;endArrow=block;" edge="1" parent="1" source="ag-gap2" target="ag-target"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag-e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2f7d8c;endArrow=block;" edge="1" parent="1" source="ag-gap3" target="ag-target"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag-e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2f7d8c;endArrow=block;" edge="1" parent="1" source="ag-gap4" target="ag-target"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag-e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2f7d8c;endArrow=block;" edge="1" parent="1" source="ag-gap5" target="ag-target"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
