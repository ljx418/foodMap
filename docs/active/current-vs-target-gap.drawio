  <diagram id="p26-07-gate" name="07 验收门槛与出门条件">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p7_title" value="P26 验收门槛与出门条件：体验达成、证据可复跑、边界不越线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1"><mxGeometry x="60" y="30" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p7_user" value="用户体验门槛&#xa;Mate70 固定 URL 可进入&#xa;浏览器/WebApp/失败状态清楚&#xa;创建、详情、筛选、导入导出、分享可触达&#xa;本地数据维护可预览可取消可确认" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1"><mxGeometry x="80" y="150" width="300" height="250" as="geometry" /></mxCell>
        <mxCell id="p7_tech" value="技术门槛&#xa;build / unit / scanlist 通过&#xa;静态部署 verifier 通过&#xa;hash route 直达与刷新通过&#xa;P18-P25 回归通过&#xa;P26 targeted E2E 通过" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="540" y="150" width="300" height="250" as="geometry" /></mxCell>
        <mxCell id="p7_boundary" value="边界门槛&#xa;不做原生 HAP / AppGallery&#xa;不做账号、云同步、后端&#xa;不做永久公网分享&#xa;不承诺离线地图或实时 POI 完成&#xa;不静默删除/合并/修复/固化坐标" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1"><mxGeometry x="1000" y="150" width="300" height="250" as="geometry" /></mxCell>
        <mxCell id="p7_exit" value="出门条件&#xa;1. P26 final report 存在且列出命令、截图/JSON、Mate70 证据、PRD 检视、残余限制&#xa;2. 真实数据和 Mate70 验收通过，桌面模拟不替代真机&#xa;3. 文档、drawio、E2E matrix、visual checklist 与实现一致&#xa;4. 没有未闭环的致命或重大规格偏差/虚假验收风险" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=left;spacingLeft=14;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1"><mxGeometry x="240" y="535" width="920" height="150" as="geometry" /></mxCell>
        <mxCell id="p7_e1" edge="1" parent="1" source="p7_user" target="p7_exit" style="endArrow=block;html=1;strokeColor=#d6b656"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p7_e2" edge="1" parent="1" source="p7_tech" target="p7_exit" style="endArrow=block;html=1;strokeColor=#6c8ebf"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p7_e3" edge="1" parent="1" source="p7_boundary" target="p7_exit" style="endArrow=block;html=1;strokeColor=#b85450"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
