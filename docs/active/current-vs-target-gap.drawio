  <diagram id="p26-02-gap" name="02 当前P25与P26目标差异">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p2_title" value="当前架构与目标架构差异：P25 固定 URL 基线到 P26 移动发布硬化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1"><mxGeometry x="60" y="30" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p2_current" value="当前 P25 架构实体&#xa;vite.config.ts / gh-pages / dist&#xa;index.html / manifest.webmanifest / sw.js&#xa;App hash router&#xa;MapWorkspace / ShareView&#xa;ImportExportDialog / .foodmap.json&#xa;IndexedDB repositories&#xa;scripts/verify_p25_deployment.mjs&#xa;docs/active/evidence/p25" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1"><mxGeometry x="70" y="150" width="340" height="420" as="geometry" /></mxCell>
        <mxCell id="p2_modify" value="P26 需修改实体&#xa;MapWorkspace：移动主路径与状态说明&#xa;HomeMapControlDock：底部操作与筛选触达&#xa;ShareView：只读分享/缺失快照移动体验&#xa;ImportExportDialog：数据包本地语义和触控&#xa;PersonalDataHealthCenter：问题分组可读性&#xa;GovernanceWorkbench：预览/确认路径&#xa;app.css：Mate70 安全区、键盘、面板" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1"><mxGeometry x="535" y="150" width="360" height="420" as="geometry" /></mxCell>
        <mxCell id="p2_new" value="P26 待新增/强化实体&#xa;MobileReleaseEvidenceHarness&#xa;ReleaseGateAutomation&#xa;P26 release verifier / evidence manifest&#xa;docs/active/evidence/p26/&#xa;p26-final-acceptance-report.md&#xa;P26 targeted Playwright specs&#xa;P26 PRD spec review report" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="1020" y="150" width="320" height="420" as="geometry" /></mxCell>
        <mxCell id="p2_e1" edge="1" parent="1" source="p2_current" target="p2_modify" style="endArrow=block;html=1;strokeColor=#d6b656"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2_e2" edge="1" parent="1" source="p2_modify" target="p2_new" style="endArrow=block;html=1;strokeColor=#6c8ebf"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2_note" value="评估方法：每个 P26 目标必须能回到具体代码实体、发布实体、数据实体或证据实体；不能用抽象“跨端部署”“App 能力”单独判定完成。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=center;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1"><mxGeometry x="150" y="650" width="1100" height="70" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
