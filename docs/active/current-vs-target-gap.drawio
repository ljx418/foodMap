<mxfile host="app.diagrams.net" modified="2026-06-05T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="current-target-architecture" name="Current vs Target Architecture">
    <mxGraphModel dx="1420" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title1" value="FoodMap Current Stage: Architecture Gap" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="270" y="20" width="860" height="40" as="geometry"/></mxCell>
        <mxCell id="currentBox" value="Current Architecture&#xa;&#xa;Vite React TypeScript SPA&#xa;Hash routes: #/map, #/share/:id&#xa;IndexedDB: places, layers, photos, snapshots, meta&#xa;Leaflet Wuhan fallback + tile-failure schematic map&#xa;Personal CRUD, filters, photos, share, import/export&#xa;AMap Wuhan scanlist: 50 entries&#xa;Manual verified pin overlay&#xa;Recommendation image evidence&#xa;Adaptive recommendation markers&#xa;window.FoodMapAgentBridge&#xa;Vitest + Playwright baseline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8ffea;strokeColor=#00b42a;fontSize=14;align=left;spacing=14;" vertex="1" parent="1"><mxGeometry x="45" y="110" width="360" height="430" as="geometry"/></mxCell>
        <mxCell id="gapBox" value="Remaining Gap&#xa;&#xa;Current docs must stay aligned with implemented reality&#xa;POI refresh reports need stronger duplicate/source/coordinate fields for future items&#xa;Recommendation detail must stay selected-place-first&#xa;Input flow still needs required-first polish and better photo preview&#xa;Marker density needs visual evidence across zoom levels&#xa;Agent Bridge needs smoke acceptance and unsafe-save rejection evidence&#xa;Final report must combine PRD, POI, UX, agent, and visual gates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7e8;strokeColor=#ff9a2e;fontSize=14;align=left;spacing=14;" vertex="1" parent="1"><mxGeometry x="510" y="110" width="360" height="430" as="geometry"/></mxCell>
        <mxCell id="targetBox" value="Target Current-Stage Architecture&#xa;&#xa;V1.0 PRD personal food journal remains complete&#xa;Verified Wuhan recommendation overlay is first-class&#xa;Only verified/mappable recommendations become pins&#xa;Exact vs approximate coordinates are visible&#xa;Image/street-view evidence appears in detail&#xa;Adaptive ranked/green/dot marker modes preserve readability&#xa;Mobile and desktop UI expose one primary task surface at a time&#xa;Agent commands reuse UI validation and POI admission rules&#xa;Docs, drawio, tests, and evidence describe the same system" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f7ff;strokeColor=#3491fa;fontSize=14;align=left;spacing=14;" vertex="1" parent="1"><mxGeometry x="975" y="110" width="360" height="430" as="geometry"/></mxCell>
        <mxCell id="edge-current-gap" style="endArrow=block;html=1;rounded=0;strokeColor=#ff7d00;strokeWidth=2;" edge="1" parent="1" source="currentBox" target="gapBox"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="edge-gap-target" style="endArrow=block;html=1;rounded=0;strokeColor=#165dff;strokeWidth=2;" edge="1" parent="1" source="gapBox" target="targetBox"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uiLayer" value="UI Feature Layer&#xa;Workspace header, map canvas, display panel, place list/detail, recommendation detail, editor modal, filter/import/share dialogs, mobile sheets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c9cdd4;fontSize=14;" vertex="1" parent="1"><mxGeometry x="90" y="620" width="1220" height="58" as="geometry"/></mxCell>
        <mxCell id="domainLayer" value="Domain + Persistence Layer&#xa;FoodPlace, FoodLayer, PhotoAsset, ShareSnapshot, FoodFilterState, validators, filters, IndexedDB repositories, .foodmap.json codec" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c9cdd4;fontSize=14;" vertex="1" parent="1"><mxGeometry x="90" y="700" width="1220" height="58" as="geometry"/></mxCell>
        <mxCell id="mapLayer" value="Map + Recommendation Layer&#xa;MapProviderAdapter, Leaflet/AMap path, Wuhan fallback, AMAP_WUHAN_SCANLIST, manualVerifiedPins, verification, adaptive markers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c9cdd4;fontSize=14;" vertex="1" parent="1"><mxGeometry x="90" y="780" width="600" height="58" as="geometry"/></mxCell>
        <mxCell id="agentLayer" value="Agent + Verification Layer&#xa;FoodMapAgentBridge, command/result/state events, Vitest, Playwright, scanlist report, UX audit, final acceptance evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c9cdd4;fontSize=14;" vertex="1" parent="1"><mxGeometry x="710" y="780" width="600" height="58" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
