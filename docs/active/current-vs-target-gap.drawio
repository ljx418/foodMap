        <mxCell id="m1" value="M18-1 文档冻结" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;" vertex="1" parent="1"><mxGeometry x="90" y="200" width="130" height="70" as="geometry" /></mxCell>
