        <mxCell id="p1_legend1" value="已实现/P25基线" style="rounded=1;whiteSpace=wrap;html=1;align=center;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1"><mxGeometry x="80" y="115" width="150" height="34" as="geometry" /></mxCell>
