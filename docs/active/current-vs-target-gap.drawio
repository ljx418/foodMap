          <mxGeometry x="1010" y="195" width="310" height="250" as="geometry" />
        </mxCell>
        <mxCell id="p1_no" value="不能当作 P27 出门：GitHub Pages、localhost、局域网 IP、HDC reverse、临时 tunnel、EdgeOne 受保护预览、带完整 preview token 的 URL。&#xa;不能新增：账号、云同步、后端、永久公网分享、原生 HAP/AppGallery、离线地图、实时 POI 完成声明。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=center;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
