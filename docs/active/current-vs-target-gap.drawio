        <mxCell id="ms-1" value="M17-1&#xa;文档冻结&#xa;&#xa;完成定义：active 文档和 drawio 均指向 P17。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8ea;strokeColor=#c76a32;fontSize=15;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="140" width="170" height="130" as="geometry" /></mxCell>
        <mxCell id="ms-2" value="M17-2&#xa;待确认工作台&#xa;&#xa;完成定义：待确认地点可集中处理。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=15;align=center;" vertex="1" parent="1"><mxGeometry x="285" y="140" width="170" height="130" as="geometry" /></mxCell>
        <mxCell id="ms-3" value="M17-3&#xa;详情页重构&#xa;&#xa;完成定义：多尺寸无截断，标签和操作可发现。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=15;align=center;" vertex="1" parent="1"><mxGeometry x="490" y="140" width="170" height="130" as="geometry" /></mxCell>
