  <diagram id="p18-gates" name="05 验收门槛及出门条件">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title5" value="P18 验收门槛：六条工作流全部通过才允许出门" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="40" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="gateA" value="候选与 provider 门槛&#xa;搜索入口可见&#xa;无 Key 有 fallback&#xa;候选显示来源/置信度/坐标精度/证据&#xa;确认前不改坐标" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="90" y="170" width="360" height="170" as="geometry" /></mxCell>
        <mxCell id="gateB" value="校准与移动门槛&#xa;手动挪动保存前展示新旧坐标&#xa;支持确认/取消&#xa;刷新后保留审计兜底&#xa;待校准不提供误导导航" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5e8;strokeColor=#82b366;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="520" y="170" width="360" height="170" as="geometry" /></mxCell>
        <mxCell id="gateC" value="体验与传播门槛&#xa;移动详情核心动作可见&#xa;筛选摘要解释点数变化&#xa;分享图标题和模式生效&#xa;当前视野/当前筛选结果一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="950" y="170" width="360" height="170" as="geometry" /></mxCell>
        <mxCell id="gateD" value="数据和安全门槛&#xa;真实数据 32+50+120&#xa;500/1000/3000 点 smoke&#xa;Agent 不能固化坐标/删除/隐藏&#xa;build/test/e2e/verify 全通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="310" y="470" width="360" height="190" as="geometry" /></mxCell>
