  <diagram id="p17-gates" name="05 验收门槛及出门条件">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="gt-title" value="P17 验收门槛与出门条件" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="100" y="30" width="1200" height="50" as="geometry" /></mxCell>
        <mxCell id="gt-left" value="功能门槛&#xa;&#xa;1. 待确认入口和工作台可用&#xa;2. 候选确认、跳过、手动挪动可用&#xa;3. 详情页标签可编辑并持久化&#xa;4. 移动端主路径可完成&#xa;5. 分享图预览和导出一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8ea;strokeColor=#c76a32;fontSize=16;align=left;spacing=14;" vertex="1" parent="1"><mxGeometry x="80" y="140" width="330" height="300" as="geometry" /></mxCell>
        <mxCell id="gt-mid" value="体验门槛&#xa;&#xa;1. 多尺寸控件不截断&#xa;2. 详情页无不可滚动区域&#xa;3. 图钉选中和缩放不闪烁&#xa;4. 待校准地点不误导导航&#xa;5. 地图、列表、详情、分享图状态一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=16;align=left;spacing=14;" vertex="1" parent="1"><mxGeometry x="535" y="140" width="330" height="300" as="geometry" /></mxCell>
        <mxCell id="gt-right" value="证据门槛&#xa;&#xa;1. npm run build&#xa;2. npm test&#xa;3. npx playwright test&#xa;4. npm run verify:scanlist&#xa;5. 多尺寸截图&#xa;6. 真实数据性能记录&#xa;7. PRD 规格检视" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5ef;strokeColor=#2f7d8c;fontSize=16;align=left;spacing=14;" vertex="1" parent="1"><mxGeometry x="990" y="140" width="330" height="300" as="geometry" /></mxCell>
        <mxCell id="gt-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#806b57;endArrow=block;" edge="1" parent="1" source="gt-left" target="gt-mid"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gt-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#806b57;endArrow=block;" edge="1" parent="1" source="gt-mid" target="gt-right"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gt-exit" value="出门条件&#xa;&#xa;所有 blocker gate 通过；真实数据覆盖扫街榜、参考层、个人收藏和待确认队列；移动端完整链路可验收；active 文档与实现一致；阶段验收摘要已创建。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4efe4;strokeColor=#d8c5a5;fontSize=18;fontStyle=1;align=center;spacing=16;" vertex="1" parent="1"><mxGeometry x="285" y="580" width="830" height="170" as="geometry" /></mxCell>
        <mxCell id="gt-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2f7d8c;endArrow=block;" edge="1" parent="1" source="gt-right" target="gt-exit"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
