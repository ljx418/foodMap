        <mxCell id="pl-1" value="P17-1 文档冻结&#xa;PRD/架构/计划/门槛/里程碑/drawio/contract 一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8ea;strokeColor=#c76a32;fontSize=15;align=center;" vertex="1" parent="1"><mxGeometry x="55" y="155" width="180" height="105" as="geometry" /></mxCell>
