  <diagram id="p27-07-gates" name="07 验收门槛与出门条件">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p7_title" value="P27 验收门槛与出门条件：用户体验、工程证据和不可验收状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="1280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p7_user" value="用户体验门槛&#xa;大陆稳定 HTTPS URL 可打开&#xa;无需登录 / token / LAN / HDC / tunnel&#xa;Mate70 完成工作台、详情筛选、数据包、分享 fallback 或有效 share、刷新恢复&#xa;用户理解本地数据仍在浏览器" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="360" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p7_engineering" value="工程证据门槛&#xa;build:mainland 通过&#xa;build:edgeone 通过&#xa;verify:mainland:deployment 本地通过&#xa;remote verifier 通过&#xa;浏览器 smoke 截图&#xa;P18-P26 回归边界未破坏" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="520" y="150" width="360" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p7_report" value="报告与安全门槛&#xa;P27 final report 存在&#xa;provider / URL / ICP / HTTPS 已记录&#xa;PRD review 已完成&#xa;blockers / residual limits 明确&#xa;无 API token、cookie、SecretKey、完整 preview token 泄漏" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="960" y="150" width="360" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p7_fail" value="一票否决：GitHub Pages 被当大陆生产入口；只有 localhost、LAN、HDC、临时 tunnel；EdgeOne 受保护预览被当公网验收；远端 URL 需要登录或临时 token；未确认付费、域名、ICP、HTTPS、控制台操作；任何秘密写入仓库。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=center;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="170" y="500" width="1060" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p7_exit" value="出门结论只能二选一：&#xa;Accepted：稳定公网 URL + 远端验证 + Mate70 证据 + final report 全部成立。&#xa;Not accepted / blocked：外部平台、域名、ICP、HTTPS、付费、protected preview 或验收失败仍未闭环。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;align=center;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="240" y="675" width="920" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
