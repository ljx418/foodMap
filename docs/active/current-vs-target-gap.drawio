  <diagram id="p26-04-release" name="04 发布与真机证据链路">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p4_title" value="P26 发布与真机证据链路：不把桌面模拟、HDC 或旧截图冒充最终验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1"><mxGeometry x="60" y="30" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p4_cmd" value="发布门禁命令&#xa;npm run build&#xa;npm test -- --run&#xa;npm run verify:scanlist&#xa;verify:p25:deployment / P26 successor&#xa;P18-P25 regression&#xa;P26 targeted E2E" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="90" y="155" width="300" height="285" as="geometry" /></mxCell>
        <mxCell id="p4_host" value="部署站点证据&#xa;GitHub Pages 固定 URL&#xa;#/map 直达与刷新&#xa;#/share/:snapshotId 直达与刷新&#xa;source-down fallback&#xa;tile failure fallback" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1"><mxGeometry x="540" y="155" width="300" height="285" as="geometry" /></mxCell>
        <mxCell id="p4_phone" value="Mate70 真机证据&#xa;固定 URL 入口&#xa;工作台/创建/详情/筛选&#xa;导入导出/数据包&#xa;有效只读分享&#xa;缺失分享恢复&#xa;刷新持久化&#xa;键盘与安全区" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1"><mxGeometry x="990" y="155" width="300" height="285" as="geometry" /></mxCell>
        <mxCell id="p4_report" value="证据治理输出&#xa;docs/active/evidence/p26/manifest.json&#xa;截图/录屏/JSON 命令日志&#xa;PRD 规格检视&#xa;p26-final-acceptance-report.md&#xa;残余限制与 blocker" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1"><mxGeometry x="360" y="555" width="680" height="120" as="geometry" /></mxCell>
        <mxCell id="p4_bad" value="失败判定&#xa;仅 desktop mobile 视口、仅 HDC、仅本地 preview、临时 URL、旧截图、无 scanlist、无 final report 均不能宣布 P26 accepted" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1"><mxGeometry x="260" y="705" width="880" height="65" as="geometry" /></mxCell>
        <mxCell id="p4_e1" edge="1" parent="1" source="p4_cmd" target="p4_host" style="endArrow=block;html=1;strokeColor=#6c8ebf"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p4_e2" edge="1" parent="1" source="p4_host" target="p4_phone" style="endArrow=block;html=1;strokeColor=#d6b656"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p4_e3" edge="1" parent="1" source="p4_phone" target="p4_report" style="endArrow=block;html=1;strokeColor=#666666"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p26-05-plan" name="05 开发及验收计划">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5_title" value="P26 开发及验收计划：每个子阶段先计划/审计，再实现，再端到端验收与 PRD 检视" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1"><mxGeometry x="60" y="30" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p5_1" value="P26-1 文档审计与边界冻结&#xa;效果：开发者知道做什么、不做什么、怎么验收" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="70" y="150" width="180" height="115" as="geometry" /></mxCell>
        <mxCell id="p5_2" value="P26-2 移动端发布体验硬化&#xa;效果：Mate70 用户看懂固定 URL 与失败状态" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1"><mxGeometry x="265" y="150" width="180" height="115" as="geometry" /></mxCell>
        <mxCell id="p5_3" value="P26-3 发布门禁自动化&#xa;效果：发布前能复跑命令和证据 manifest" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="460" y="150" width="180" height="115" as="geometry" /></mxCell>
        <mxCell id="p5_4" value="P26-4 Mate70 交互精修&#xa;效果：创建、详情、筛选、分享更少误触遮挡" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1"><mxGeometry x="655" y="150" width="180" height="115" as="geometry" /></mxCell>
        <mxCell id="p5_5" value="P26-5 本地数据维护增强&#xa;效果：重复、冲突、待确认、导入问题可看清可确认" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1"><mxGeometry x="850" y="150" width="180" height="115" as="geometry" /></mxCell>
        <mxCell id="p5_6" value="P26-6 回归与证据包&#xa;效果：P18-P25 不被破坏，截图/JSON 可审计" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1"><mxGeometry x="1045" y="150" width="180" height="115" as="geometry" /></mxCell>
        <mxCell id="p5_7" value="P26-7 总验收&#xa;效果：只有证据齐全才写 final report 并宣布 accepted" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1"><mxGeometry x="615" y="360" width="210" height="115" as="geometry" /></mxCell>
        <mxCell id="p5_audit" value="每阶段固定循环&#xa;1. 根据 PRD 写开发/验收计划&#xa;2. 审计规格偏差和虚假验收风险&#xa;3. 闭环致命/重大风险&#xa;4. 实现&#xa;5. 真实数据或 Mate70 端到端验收&#xa;6. PRD 规格检视&#xa;7. 失败则回到计划阶段" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=left;spacingLeft=14;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1"><mxGeometry x="190" y="555" width="1020" height="130" as="geometry" /></mxCell>
        <mxCell id="p5_edge1" edge="1" parent="1" source="p5_1" target="p5_2" style="endArrow=block;html=1;strokeColor=#666666"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p5_edge2" edge="1" parent="1" source="p5_2" target="p5_3" style="endArrow=block;html=1;strokeColor=#666666"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p5_edge3" edge="1" parent="1" source="p5_3" target="p5_4" style="endArrow=block;html=1;strokeColor=#666666"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p5_edge4" edge="1" parent="1" source="p5_4" target="p5_5" style="endArrow=block;html=1;strokeColor=#666666"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p5_edge5" edge="1" parent="1" source="p5_5" target="p5_6" style="endArrow=block;html=1;strokeColor=#666666"><mxGeometry relative="1" as="geometry" /></mxCell>
