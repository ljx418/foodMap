        <mxCell id="p6_m1" value="M26-1 文档与审计基线&#xa;证据：P26 docs + drawio validation" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="100" y="145" width="280" height="90" as="geometry" /></mxCell>
