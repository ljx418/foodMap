<mxfile host="app.diagrams.net" modified="2026-06-24T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="p22-01-overview" name="01 目标体验与评估方法">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p1_title" value="P22 目标体验总览：让已验收的本地优先美食地图真正好用、好懂、好验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center;verticalAlign=middle" vertex="1" parent="1"><mxGeometry x="60" y="35" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p1_base" value="已验收基线&#xa;P18：候选搜索与可信校准&#xa;P19：当前视野分享图、数据健康&#xa;P20-C：治理工作台与安全写入&#xa;P21：本地只读快照与 .foodmap.json 可携带" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#82b366;fillColor=#e1f5e8" vertex="1" parent="1"><mxGeometry x="70" y="145" width="330" height="260" as="geometry" /></mxCell>
        <mxCell id="p1_target" value="P22 用户目标体验&#xa;1. 只读分享页像独立查看页&#xa;2. 缺失快照可直接导入恢复&#xa;3. 数据健康/治理面板能读、能操作&#xa;4. 移动端顶部控制不挤压地图&#xa;5. 数据包/分享图/快照动作可区分&#xa;6. 不新增云分享、账号、自动修复承诺" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="520" y="130" width="390" height="300" as="geometry" /></mxCell>
        <mxCell id="p1_accept" value="架构评估方法&#xa;看第 2 页：当前架构与目标架构差异是否闭合&#xa;看第 3 页：功能实体、数据实体、只读边界、写入边界是否清楚&#xa;看第 4 页：用户路径是否能达到目标体验&#xa;看第 5-7 页：计划、里程碑、门槛是否覆盖功能和验收，且没有过度承诺" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#d6b656;fillColor=#fff2cc" vertex="1" parent="1"><mxGeometry x="1010" y="145" width="330" height="285" as="geometry" /></mxCell>
        <mxCell id="p1_flow" value="" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p1_base" target="p1_target"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p1_flow2" value="" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p1_target" target="p1_accept"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p22-02-architecture-gap" name="02 当前架构与目标架构差异">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="p2_title" value="P22 当前架构与目标架构差异：不扩能力，只收口交互壳层与可读性" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center;verticalAlign=middle" vertex="1" parent="1"><mxGeometry x="60" y="35" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p2_current_ui" value="当前体验层&#xa;MapWorkspace&#xa;ShareView&#xa;WorkspaceHeader&#xa;ImportExportDialog&#xa;ShareSnapshotDialog&#xa;HomeMapControlDock" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#82b366;fillColor=#e1f5e8" vertex="1" parent="1"><mxGeometry x="70" y="145" width="280" height="220" as="geometry" /></mxCell>
        <mxCell id="p2_current_problem" value="当前问题&#xa;分享页独立感不足&#xa;缺失快照恢复路径弱&#xa;健康/治理面板可能过窄&#xa;移动顶部 dock 过占空间&#xa;导入/导出/分享语义混杂" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#b85450;fillColor=#f8cecc" vertex="1" parent="1"><mxGeometry x="430" y="145" width="300" height="220" as="geometry" /></mxCell>
        <mxCell id="p2_target_ui" value="P22 目标体验层&#xa;ReadOnlyShareShell&#xa;MissingSnapshotRecovery&#xa;WorkspacePanelReadability&#xa;MobileControlCompactness&#xa;ActionIntentLanguage&#xa;P22RegressionHarness" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="820" y="145" width="330" height="240" as="geometry" /></mxCell>
        <mxCell id="p2_boundaries" value="不变边界&#xa;IndexedDB 本地事实源&#xa;P18 坐标确认规则&#xa;P20-C 治理写入确认&#xa;P21 导入包校验与只读快照&#xa;Agent 只读/建议边界&#xa;无后端、无账号、无云分享" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#d6b656;fillColor=#fff2cc" vertex="1" parent="1"><mxGeometry x="360" y="485" width="680" height="180" as="geometry" /></mxCell>
        <mxCell id="p2_e1" value="发现差异" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p2_current_ui" target="p2_current_problem"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2_e2" value="收口到目标壳层" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p2_current_problem" target="p2_target_ui"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2_e3" value="受边界约束" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p2_boundaries" target="p2_target_ui"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p22-03-entities" name="03 功能实体与关联关系">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="p3_title" value="P22 功能实体与架构关联：体验壳层连接既有本地事实源，不新增事实模型" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center;verticalAlign=middle" vertex="1" parent="1"><mxGeometry x="60" y="35" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p3_workspace" value="MapWorkspace&#xa;个人地图工作台&#xa;筛选/图层/详情/健康/治理/海报/快照入口" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#82b366;fillColor=#e1f5e8" vertex="1" parent="1"><mxGeometry x="80" y="150" width="300" height="150" as="geometry" /></mxCell>
        <mxCell id="p3_share" value="ReadOnlyShareShell&#xa;#/share/:snapshotId&#xa;只读提示、图层面板、地图、详情面板、移动分享导航" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="520" y="145" width="360" height="170" as="geometry" /></mxCell>
        <mxCell id="p3_recovery" value="MissingSnapshotRecovery&#xa;导入 .foodmap.json&#xa;validateSnapshotPackageText&#xa;importSnapshotText&#xa;navigateToShare" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="1010" y="145" width="300" height="170" as="geometry" /></mxCell>
        <mxCell id="p3_data" value="IndexedDB 本地事实源&#xa;places / layers / photos / snapshots / governanceJournal&#xa;导入前校验，写入后只读查看" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#d6b656;fillColor=#fff2cc" vertex="1" parent="1"><mxGeometry x="390" y="430" width="420" height="155" as="geometry" /></mxCell>
        <mxCell id="p3_panels" value="WorkspacePanelReadability&#xa;is-wide-panel / is-medium-panel&#xa;数据健康、治理、待确认不再窄条化" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="80" y="430" width="260" height="155" as="geometry" /></mxCell>
        <mxCell id="p3_mobile" value="MobileControlCompactness&#xa;紧凑顶部 dock&#xa;底部主操作保留&#xa;移动分享页底部只读导航" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="870" y="430" width="270" height="155" as="geometry" /></mxCell>
        <mxCell id="p3_e1" value="生成/打开快照" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p3_workspace" target="p3_share"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_e2" value="缺失时恢复" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p3_recovery" target="p3_share"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_e3" value="读/写校验后快照" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p3_share" target="p3_data"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_e4" value="同一事实源" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p3_workspace" target="p3_data"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_e5" value="桌面可读" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p3_panels" target="p3_workspace"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_e6" value="移动可达" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p3_mobile" target="p3_share"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p22-04-flows" name="04 目标体验与关键路径">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="p4_title" value="P22 开发完成后用户能体验到什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center;verticalAlign=middle" vertex="1" parent="1"><mxGeometry x="60" y="35" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p4_share" value="路径 A：只读分享查看&#xa;打开 #/share/:snapshotId&#xa;→ 看见本地只读提示&#xa;→ 左侧切图层 / 中间看地图 / 右侧看详情&#xa;→ 移动端用 图层/清单/详情 导航&#xa;目标效果：查看者不用理解编辑工作台，也不会误以为能修改原数据" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="70" y="145" width="380" height="255" as="geometry" /></mxCell>
        <mxCell id="p4_missing" value="路径 B：缺失快照恢复&#xa;打开不存在的分享链接&#xa;→ 页面说明需要本地 .foodmap.json&#xa;→ 直接导入文件&#xa;→ 校验成功后跳转分享页&#xa;→ 校验失败显示错误且不污染个人地图" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="510" y="145" width="380" height="255" as="geometry" /></mxCell>
        <mxCell id="p4_workspace" value="路径 C：个人工作台维护&#xa;打开数据健康或治理工作台&#xa;→ 宽面板显示分组、说明、按钮&#xa;→ 移动端顶部 dock 保持紧凑&#xa;→ 用户能继续围绕地图处理个人地点&#xa;目标效果：治理不是后台表格，而是地图维护辅助" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="950" y="145" width="380" height="255" as="geometry" /></mxCell>
        <mxCell id="p4_language" value="文案体验&#xa;数据包：导入/导出 .foodmap.json&#xa;分享图：生成 PNG 海报&#xa;快照：生成本地只读分享快照&#xa;目标效果：用户知道每个动作的产物和边界" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#d6b656;fillColor=#fff2cc" vertex="1" parent="1"><mxGeometry x="330" y="500" width="740" height="160" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p22-05-plan" name="05 开发及验收计划">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="p5_title" value="P22 开发及验收计划：每个子阶段先审计，再实现，再端到端验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center;verticalAlign=middle" vertex="1" parent="1"><mxGeometry x="60" y="35" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p5_1" value="P22-1 文档与审计基线&#xa;产物：计划、预审计、PRD/架构/gap/drawio 更新&#xa;验收：无致命或重大规格偏差" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#82b366;fillColor=#e1f5e8" vertex="1" parent="1"><mxGeometry x="80" y="150" width="280" height="145" as="geometry" /></mxCell>
        <mxCell id="p5_2" value="P22-2 只读分享页&#xa;产物：独立 share shell、移动只读导航、缺失快照导入&#xa;验收：P21 targeted 与截图" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="410" y="150" width="280" height="145" as="geometry" /></mxCell>
        <mxCell id="p5_3" value="P22-3 工作台可读性&#xa;产物：宽右栏、紧凑移动 dock、意图文案&#xa;验收：P22 workspace shell E2E" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="740" y="150" width="280" height="145" as="geometry" /></mxCell>
        <mxCell id="p5_4" value="P22-4 回归与证据&#xa;产物：build/unit/scanlist/P21/core/P22 结果、截图、final report&#xa;验收：所有门槛通过才 accepted" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="1070" y="150" width="280" height="145" as="geometry" /></mxCell>
        <mxCell id="p5_cmd" value="必跑命令&#xa;npm run build&#xa;npm test -- --run&#xa;npm run verify:scanlist&#xa;P21 targeted Playwright&#xa;P19/P20 core targeted Playwright&#xa;P22 workspace shell Playwright" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#d6b656;fillColor=#fff2cc" vertex="1" parent="1"><mxGeometry x="300" y="450" width="800" height="190" as="geometry" /></mxCell>
        <mxCell id="p5_e1" value="" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p5_1" target="p5_2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p5_e2" value="" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p5_2" target="p5_3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p5_e3" value="" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="p5_3" target="p5_4"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p22-06-milestones" name="06 项目里程碑">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="p6_title" value="P22 项目里程碑：从发布候选功能完成，到交互体验可出门" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center;verticalAlign=middle" vertex="1" parent="1"><mxGeometry x="60" y="35" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p6_m1" value="M22-1&#xa;文档与审计基线&#xa;P22 scope 清楚且无过度承诺" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;verticalAlign=middle;strokeColor=#82b366;fillColor=#e1f5e8" vertex="1" parent="1"><mxGeometry x="80" y="180" width="210" height="140" as="geometry" /></mxCell>
        <mxCell id="p6_m2" value="M22-2&#xa;只读分享页独立化&#xa;图层/地图/详情/移动导航可见" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="340" y="180" width="210" height="140" as="geometry" /></mxCell>
        <mxCell id="p6_m3" value="M22-3&#xa;缺失快照恢复&#xa;错误页可直接导入 .foodmap.json" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="600" y="180" width="210" height="140" as="geometry" /></mxCell>
        <mxCell id="p6_m4" value="M22-4&#xa;工作台可读性&#xa;宽面板与移动 dock 通过 E2E" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="860" y="180" width="210" height="140" as="geometry" /></mxCell>
        <mxCell id="p6_m5" value="M22-5&#xa;回归总验收&#xa;build/unit/scanlist/E2E/final report 全通过" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="1120" y="180" width="210" height="140" as="geometry" /></mxCell>
        <mxCell id="p6_exit" value="里程碑完成后可声明的效果&#xa;FoodMap 仍是纯前端、本地优先、地图优先的武汉美食地图；用户可以更清楚地区分数据包、分享图、只读快照，并能在桌面和移动端理解、查看、恢复和维护自己的本地地图。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#d6b656;fillColor=#fff2cc" vertex="1" parent="1"><mxGeometry x="260" y="500" width="880" height="145" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p22-07-gates" name="07 验收门槛与出门条件">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="p7_title" value="P22 验收门槛与出门条件：验用户体验，也验架构边界" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center;verticalAlign=middle" vertex="1" parent="1"><mxGeometry x="60" y="35" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="p7_user" value="用户体验门槛&#xa;1. 分享页桌面端图层/地图/详情同屏可读&#xa;2. 分享页移动端可切换图层/清单/详情&#xa;3. 缺失快照可直接导入恢复&#xa;4. 数据健康和治理面板不窄条化&#xa;5. 移动顶部 dock 不遮挡主地图路径&#xa;6. 数据包/分享图/快照文案一致" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#dae8fc" vertex="1" parent="1"><mxGeometry x="80" y="145" width="380" height="300" as="geometry" /></mxCell>
        <mxCell id="p7_arch" value="架构边界门槛&#xa;1. 不新增后端、账号、云同步、公网永久链接&#xa;2. 不绕过 P18 坐标确认&#xa;3. 不绕过 P20-C 治理确认&#xa;4. 不污染 P21 导入失败 no-op 规则&#xa;5. Agent 仍不能批量写入、固化坐标或伪造公网链接" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#d6b656;fillColor=#fff2cc" vertex="1" parent="1"><mxGeometry x="510" y="145" width="380" height="300" as="geometry" /></mxCell>
        <mxCell id="p7_evidence" value="证据门槛&#xa;build 通过&#xa;unit 通过&#xa;verify:scanlist 真实数据通过&#xa;P21 targeted 通过&#xa;P19/P20 core targeted 通过&#xa;P22 workspace shell 通过&#xa;截图和 final report 存档" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;verticalAlign=middle;strokeColor=#82b366;fillColor=#e1f5e8" vertex="1" parent="1"><mxGeometry x="940" y="145" width="380" height="300" as="geometry" /></mxCell>
        <mxCell id="p7_exit" value="出门条件&#xa;上述三组门槛全部通过，且 docs/active/p22-final-acceptance-report.md 记录命令、截图、真实数据、PRD 检视、架构边界和残余风险后，才能声明 P22 accepted。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#b85450;fillColor=#f8cecc" vertex="1" parent="1"><mxGeometry x="260" y="560" width="880" height="120" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
