        <mxCell id="p5_title" value="P25 开发及验收计划：每个子阶段先审计、再开发、再端到端验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1">
