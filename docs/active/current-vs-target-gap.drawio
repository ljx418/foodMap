  <diagram id="p27-04-evidence" name="04 公网访问与证据链路">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p4_title" value="P27 证据链路：什么能证明公网访问，什么只能证明开发或预览" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="1280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4_build" value="1 构建证据&#xa;npm run build:mainland&#xa;npm run build:edgeone&#xa;npm run verify:mainland:deployment" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="90" y="160" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p4_deploy" value="2 部署证据&#xa;EDGEONE_DRY_RUN=1 deploy:edgeone&#xa;真实部署不打印 token&#xa;provider 返回 URL 状态" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="410" y="160" width="250" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p4_url" value="3 URL 分类&#xa;稳定公网 HTTPS：可进入下一步&#xa;受保护预览：只能 smoke&#xa;GitHub/LAN/HDC/tunnel：不可出门" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="745" y="160" width="250" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p4_remote" value="4 远端验证&#xa;FOODMAP_MAINLAND_DEPLOY_URL&#xa;verify:mainland:deployment&#xa;#/map / refresh / share fallback&#xa;manifest / sw / assets" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="1080" y="160" width="250" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p4_browser" value="5 浏览器 smoke&#xa;打开稳定 URL&#xa;截图或 trace&#xa;缺失分享 fallback&#xa;本地优先说明可见" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="260" y="450" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p4_mate" value="6 Mate70 证据&#xa;同一稳定 URL&#xa;工作台 / 详情筛选 / 数据包&#xa;分享 fallback 或有效 share&#xa;刷新恢复 / release status" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="585" y="450" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p4_report" value="7 Final report&#xa;provider / URL / ICP / HTTPS&#xa;命令 / 截图 / PRD review&#xa;blockers / residual limits&#xa;非目标 / secret redaction" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="940" y="450" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p4_e1" edge="1" parent="1" source="p4_build" target="p4_deploy" style="endArrow=block;html=1;strokeColor=#666666">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p4_e2" edge="1" parent="1" source="p4_deploy" target="p4_url" style="endArrow=block;html=1;strokeColor=#666666">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p4_e3" edge="1" parent="1" source="p4_url" target="p4_remote" style="endArrow=block;html=1;strokeColor=#666666">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p4_e4" edge="1" parent="1" source="p4_remote" target="p4_browser" style="endArrow=block;html=1;strokeColor=#6c8ebf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p4_e5" edge="1" parent="1" source="p4_browser" target="p4_mate" style="endArrow=block;html=1;strokeColor=#6c8ebf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p4_e6" edge="1" parent="1" source="p4_mate" target="p4_report" style="endArrow=block;html=1;strokeColor=#6c8ebf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p27-05-plan" name="05 开发及验收计划">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5_title" value="P27 开发及验收计划：每阶段产物、验收动作和用户体验结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="1280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p5_1" value="P27-1 文档审计&#xa;产物：PRD / 架构 / gate / roadmap / gap / drawio / profile 同步&#xa;体验结果：开发方向不偏移、不承诺云或原生" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=left;spacingLeft=10;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="70" y="145" width="360" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p5_2" value="P27-2 状态归类&#xa;产物：URL 状态矩阵&#xa;验收：GitHub / LAN / HDC / tunnel / protected preview 均不可出门&#xa;体验结果：不做虚假公网验收" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=left;spacingLeft=10;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="520" y="145" width="360" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p5_3" value="P27-3 路线准备&#xa;产物：EdgeOne 免费优先 + COS/OSS 备选&#xa;验收：域名 / ICP / HTTPS / 付费风险明确&#xa;体验结果：用户知道要提供哪些外部条件" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=left;spacingLeft=10;fillColor=#fce5cd;strokeColor=#d79b00" vertex="1" parent="1">
          <mxGeometry x="970" y="145" width="360" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p5_4" value="P27-4 自动化验证&#xa;产物：build:mainland / build:edgeone / deploy:edgeone / verify:mainland:deployment 证据&#xa;体验结果：发布者可复跑发布门禁" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=left;spacingLeft=10;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="70" y="410" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p5_5" value="P27-5 Mate70 公网验收&#xa;产物：稳定 URL 真机截图或录屏&#xa;验收：工作台、详情筛选、数据包、分享 fallback、刷新恢复可用&#xa;体验结果：Mate70 用户可真实访问" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=left;spacingLeft=10;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="520" y="410" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p5_6" value="P27-6 总验收&#xa;产物：P27 final report&#xa;验收：回归、PRD review、截图、远端 verify、secret redaction 全部记录&#xa;体验结果：可诚实宣布接受或不接受" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=left;spacingLeft=10;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="970" y="410" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p5_note" value="失败回退规则：若任一验收失败，必须回到相应计划阶段修订路线或记录 blocker。若出现付费、域名、ICP、HTTPS、控制台操作或秘密泄漏风险，停止并找用户确认。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=center;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
