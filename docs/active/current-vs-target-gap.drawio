  <diagram id="p25-01-overview" name="01 P25目标体验与边界">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p1_title" value="P25 目标体验：Mate70 通过稳定静态 URL 使用本地优先 FoodMap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="1280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p1_base" value="已验收基线&#xa;P18：候选搜索、风险提示、坐标确认&#xa;P19：当前视野分享图、数据健康中心&#xa;P20-C：治理工作台、安全批量写入&#xa;P21：本地只读快照、.foodmap.json&#xa;P22/P23：交互可读性纠偏&#xa;P24：WebApp/Mate70 临时部署验收" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#e1f5e8;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="70" y="145" width="360" height="310" as="geometry" />
        </mxCell>
        <mxCell id="p1_goal" value="P25 用户可见目标&#xa;1. 打开 GitHub Pages 稳定 URL&#xa;2. 直接进入 #/map 地图工作台&#xa;3. 创建/查看/筛选/导入导出个人地点&#xa;4. 打开有效 #/share/:snapshotId 只读分享&#xa;5. 刷新后本地数据仍可读&#xa;6. 失败态解释清楚且不暗示云修复" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="520" y="145" width="360" height="310" as="geometry" />
        </mxCell>
        <mxCell id="p1_boundary" value="P25 明确不做&#xa;不做 HarmonyOS HAP / AppGallery&#xa;不做账号、云同步、远程备份&#xa;不做 FoodMap 业务后端 API&#xa;不做永久公网社交分享链接&#xa;不做离线地图瓦片产品&#xa;不宣称外部实时 POI 搜索完成" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="970" y="145" width="320" height="310" as="geometry" />
        </mxCell>
        <mxCell id="p1_status" value="当前状态&#xa;文档/计划阶段；实现未开始；P25 未验收。&#xa;P24 仍是最新已验收代码基线。&#xa;P25 出门必须有稳定 URL、Mate70 固定 URL 证据、P18-P24 回归和 final report。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=center;verticalAlign=middle;fillColor=#fff8ea;strokeColor=#d8c5a5" vertex="1" parent="1">
          <mxGeometry x="160" y="540" width="1080" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p1_e1" edge="1" parent="1" source="p1_base" target="p1_goal" style="endArrow=block;html=1;strokeColor=#6f7f47">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
