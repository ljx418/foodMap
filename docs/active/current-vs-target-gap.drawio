        <mxCell id="p1_base" value="已验收基线&#xa;P26 accepted&#xa;Mate70 固定 URL 证据&#xa;P18-P26 回归边界&#xa;IndexedDB 本地数据&#xa;.foodmap.json 携带&#xa;MapWorkspace / ShareView / ImportExportDialog" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="80" y="195" width="310" height="250" as="geometry" />
        </mxCell>
        <mxCell id="p1_target" value="P27 用户可见目标&#xa;大陆稳定 HTTPS URL&#xa;无需平台登录&#xa;无需临时 token&#xa;无需 LAN / HDC / tunnel&#xa;Mate70 可打开同一 URL&#xa;仍是纯前端本地优先 WebApp" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="545" y="195" width="310" height="250" as="geometry" />
        </mxCell>
