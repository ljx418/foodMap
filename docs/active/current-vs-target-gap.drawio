        <mxCell id="pl-3" value="P17-3 详情页 IA&#xa;状态、标签、操作、照片、记录、校准、导航" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf7;strokeColor=#d8c5a5;fontSize=15;align=center;" vertex="1" parent="1"><mxGeometry x="455" y="155" width="180" height="105" as="geometry" /></mxCell>
