<mxfile host="app.diagrams.net" modified="2026-06-17T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="p18-overview" name="01 P18 项目总览">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title1" value="FoodMap P18：候选搜索、可信校准与体验工作流编排" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="40" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="baseline1" value="当前基线 P17 已验收&#xa;待确认工作台 / 详情 IA / 移动主路径 / 图钉视觉 / 分享图预览 / Agent 边界" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5e8;strokeColor=#82b366;fontSize=16;" vertex="1" parent="1"><mxGeometry x="80" y="170" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="problem1" value="核心问题&#xa;用户知道地点不准，但继续找候选和安全校准的成本仍偏高" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde9d9;strokeColor=#d79b00;fontSize=16;" vertex="1" parent="1"><mxGeometry x="535" y="170" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="target1" value="P18 目标&#xa;候选可搜索、证据可追溯、无 Key 可降级、坐标变更可审计、移动详情更清晰、筛选可解释、分享图更适合传播" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;" vertex="1" parent="1"><mxGeometry x="990" y="170" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="scope1" value="六条开发工作流&#xa;W18-A 坐标准确性与候选校准&#xa;W18-B 详情页和移动主路径&#xa;W18-C 首页筛选与图层解释&#xa;W18-D 分享传播体验&#xa;W18-E 数据健康与性能&#xa;W18-F Agent 和验收治理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="80" y="430" width="560" height="260" as="geometry" /></mxCell>
        <mxCell id="nongoal1" value="非目标边界&#xa;不做后端 POI 服务&#xa;不自动修正所有地点&#xa;不做账号/云同步&#xa;不把 provider Key 上传云端&#xa;不牺牲地图主视图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="760" y="430" width="560" height="260" as="geometry" /></mxCell>
        <mxCell id="edge1a" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="baseline1" target="problem1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edge1b" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="problem1" target="target1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edge1c" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#b85450;" edge="1" parent="1" source="target1" target="scope1"><mxGeometry relative="1" as="geometry"><mxPoint x="350" y="400" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="edge1d" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="target1" target="nongoal1"><mxGeometry relative="1" as="geometry"><mxPoint x="1040" y="400" as="targetPoint" /></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p18-architecture-gap" name="02 当前架构与目标架构差异">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title2" value="P18 架构差异：从可纠错到更容易可信校准" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="40" width="1280" height="70" as="geometry" /></mxCell>
        <mxCell id="current2" value="当前架构 P17&#xa;Workspace UI&#xa;PendingPlaceWorkbench&#xa;PlaceDetailDrawer&#xa;PinMoveController&#xa;FilterCommandBar&#xa;SharePosterPreview&#xa;AgentPendingPlaceContext" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5e8;strokeColor=#82b366;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="80" y="170" width="300" height="270" as="geometry" /></mxCell>
        <mxCell id="gap2" value="主要差异&#xa;候选入口分散&#xa;候选证据不够完整&#xa;无 Key fallback 偏弱&#xa;挪动前缺少新旧坐标预览&#xa;移动详情仍有信息密度压力&#xa;筛选摘要和分享图模式不足&#xa;大数据性能未扩展到 3000 点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde9d9;strokeColor=#d79b00;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="540" y="150" width="320" height="320" as="geometry" /></mxCell>
        <mxCell id="target2" value="目标架构 P18&#xa;CandidateSearchWorkbench&#xa;CandidateEvidenceModel&#xa;AmapWebSearchProvider&#xa;ExternalMapSearchFallback&#xa;PinMoveAuditPreview&#xa;MobileDetailProgressiveDisclosure&#xa;FilterStateExplainer&#xa;SharePosterComposer&#xa;PersonalDataHealthReport&#xa;LargeDatasetPerformanceHarness" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="1020" y="130" width="320" height="360" as="geometry" /></mxCell>
        <mxCell id="domain2" value="Domain / Persistence&#xa;FoodPlace&#xa;PlaceCandidate&#xa;mapAccuracy&#xa;pin move audit fallback&#xa;filter state&#xa;share snapshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;" vertex="1" parent="1"><mxGeometry x="170" y="580" width="260" height="170" as="geometry" /></mxCell>
