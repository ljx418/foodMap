        <mxCell id="p1_base" value="P25 已验收基线&#xa;GitHub Pages 固定 URL&#xa;hash route 刷新恢复&#xa;Mate70 固定 URL 证据&#xa;P18-P24 回归与 scanlist&#xa;IndexedDB + .foodmap.json 本地优先" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1"><mxGeometry x="80" y="185" width="300" height="260" as="geometry" /></mxCell>
        <mxCell id="p1_target" value="P26 用户可见目标&#xa;固定 URL 状态更清楚&#xa;源站/瓦片/缺失分享失败态更诚实&#xa;Mate70 创建、详情、筛选、导入导出、分享更少误触&#xa;本地数据维护更可读可确认&#xa;发布门禁可复跑" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1"><mxGeometry x="540" y="185" width="330" height="260" as="geometry" /></mxCell>
        <mxCell id="p1_new" value="P26 待新增治理实体&#xa;MobileReleaseEvidenceHarness&#xa;ReleaseGateAutomation&#xa;EvidenceGovernancePack&#xa;docs/active/evidence/p26/&#xa;p26-final-acceptance-report.md" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="1010" y="185" width="300" height="260" as="geometry" /></mxCell>
        <mxCell id="p1_forbidden" value="P26 明确不做&#xa;HarmonyOS HAP / AppGallery&#xa;账号、云同步、后端 API&#xa;永久公网分享链接&#xa;离线地图瓦片&#xa;外部实时 POI 完成声明&#xa;静默删除/合并/修复" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=left;spacingLeft=12;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1"><mxGeometry x="290" y="545" width="820" height="120" as="geometry" /></mxCell>
