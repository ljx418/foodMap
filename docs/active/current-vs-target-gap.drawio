        <mxCell id="p5_1" value="P25-1 文档审计&#xa;PRD/架构/gate/roadmap/gap/drawio 同步&#xa;出门：无致命或重大规格风险" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;fillColor=#fff8ea;strokeColor=#d8c5a5" vertex="1" parent="1">
