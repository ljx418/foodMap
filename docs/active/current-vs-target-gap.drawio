        <mxCell id="p6_m26" value="P26 accepted&#xa;固定 URL WebApp&#xa;Mate70 证据&#xa;release gate&#xa;本地维护增强" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;align=center;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
