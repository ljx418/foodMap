        <mxCell id="p7_title" value="P25 验收门槛与出门条件：以用户能体验到的结果为准" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1">
