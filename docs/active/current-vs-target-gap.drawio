        <mxCell id="accept2" value="Acceptance&#xa;Vitest&#xa;Playwright&#xa;真实数据 32+50+120&#xa;500/1000/3000 点 smoke&#xa;截图和 JSON 证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1"><mxGeometry x="970" y="580" width="260" height="170" as="geometry" /></mxCell>
