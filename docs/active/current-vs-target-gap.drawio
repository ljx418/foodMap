        <mxCell id="p7_g1" value="稳定部署门槛&#xa;GitHub Pages URL&#xa;dist/ 静态托管&#xa;不依赖 FoodMap backend&#xa;不是本地 preview / HDC / 临时 tunnel" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="80" y="145" width="250" height="160" as="geometry" />
